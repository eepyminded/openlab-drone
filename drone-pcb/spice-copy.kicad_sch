	(text "# Parametry wyliczone dla temperatury 25 stopni i napięciu bateri 3,7 V a Sprawność  93.41\n- 25°C + (0.211 W * 120°C/W) = 50.3°C\n- Temperatura = 25 + (0.145 * 120) = 42.4°C (przy 3V) 93.19"
		(exclude_from_sim no)
		(at 69.215 108.0516 0)
		(effects
			(font
				(size 1.0668 1.0668)
			)
			(justify left top)
		)
		(uuid "a6e5683e-4576-47e6-b67f-1fcd046240aa")
	)
	(text ".tran 0 10m\n.meas tran P_out avg I(R7)*I(R7)*2\n.meas tran P_in_bat avg -V(Bateria+)*I(V3)\n.meas tran P_in_xiao avg -V(xiao_sense_G1)*I(V2)\n.meas tran P_in_total param P_in_bat + P_in_xiao\n.meas tran Efektywnosc param (P_out/P_in_total)*100"
		(exclude_from_sim no)
		(at 57.785 45.8216 0)
		(effects
			(font
				(size 1.0668 1.0668)
			)
			(justify left top)
